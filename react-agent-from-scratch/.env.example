# Copy this file to .env and fill in your real key(s), then `make run`.
#
# LLM_PROVIDER selects the model backend: zhipu | minimax | openai.
# Only the SELECTED provider's key is required; leave the others commented.

LLM_PROVIDER=zhipu

# ---- Zhipu GLM (default) -----------------------------------------------
# Coding Plan endpoint. Key format {id}.{secret}, from open.bigmodel.cn.
ZHIPUAI_API_KEY=
# Optional overrides:
# ZHIPU_MODEL=GLM-5.1
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# ---- MiniMax -----------------------------------------------------------
# Switch on with: LLM_PROVIDER=minimax
# MINIMAX_API_KEY=
# MINIMAX_MODEL=MinMax-M3
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# ---- OpenAI ------------------------------------------------------------
# Switch on with: LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # leave blank for the official endpoint
